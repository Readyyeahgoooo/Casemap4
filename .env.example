# Artifact/runtime profile
CASEMAP_PROFILE=criminal

# Optional embedding providers
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional grounded answer providers
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Supabase public runtime config
SUPABASE_URL=https://vzqlwjibtujhrhjgwhhe.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_jbTqB00EEbq-1ukymq5MMA_4Wa6ANpj

# Server-side ingest only. Keep this empty until you intentionally add a secret key.
SUPABASE_SERVICE_ROLE_KEY=

# Optional live Neo4j runtime
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Merge Supabase `case_chunks` into POST /api/query (requires SUPABASE_* keys).
# Use "auto" or "1" to enable; default "0" keeps queries local-graph only.
CASEMAP_SUPABASE_QUERY=0
# Optional: match stored MiniLM vectors at query time (loads sentence-transformers).
CASEMAP_QUERY_EMBEDDING_BACKEND=
CASEMAP_QUERY_EMBEDDING_MODEL=
# Vector dim for pgvector column + RPC (MiniLM L6 v2 = 384).
CASEMAP_EMBEDDING_VECTOR_DIM=384
# Prefer PostgREST RPC match_case_chunks; set 0 to force legacy ilike only.
CASEMAP_SUPABASE_USE_CHUNK_RPC=1
CASEMAP_SUPABASE_CHUNK_RPC=match_case_chunks
CASEMAP_SUPABASE_CHUNK_MATCH_COUNT=24
CASEMAP_CHUNK_FTS_WEIGHT=0.35
CASEMAP_CHUNK_VEC_WEIGHT=0.65
# Dev only: allow service role for /api/query Supabase calls (never in browser).
CASEMAP_SUPABASE_ALLOW_SERVICE_QUERY=0

# Optional future vector/cloud settings
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
