  "content": "<html lang=\"en\">\n<head>\n<link href=\"/lrs/common/pd/css.css\" rel=\"stylesheet\" type=\"text/css\"/>\n<script language=\"JavaScript\" src=\"/lrs/javascript/autofsize.js\" type=\"text/JavaScript\">\n</script>\n<script type=\"text/javascript\">\n\nparent.document.title=window.document.title.replace(\"XCHRX\",\"\");\nparent.document.title=window.document.title.replace(\"999999\",\"\");\n\n</script>\n<style type=\"text/css\">\n\nbody {\nwidth: 100%;\n}\n\n</style>\n<meta content=\"noindex,nofollow\" name=\"robots\"/>\n<meta content=\"text/html; charset=utf-8\" http-equiv=\"Content-Type\"/>\n<link href=\"/css/elrs.css\" rel=\"stylesheet\" type=\"text/css\"/>\n<script language=\"JavaScript\" src=\"/js/judgment.js\" type=\"text/JavaScript\">\n</script>\n<title>\n   HCCC240/2017 HKSAR v. CHAN MAN-SUM, IVAN\n  </title>\n</head>\n<body>\n<form name=\"search_body\">\n<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">\n<tr>\n<td>\n<p style=\"text-align:right\">\n       HCCC 240/2017\n      </p>\n<p style=\"text-align:center\">\n<b>\n        IN THE HIGH COURT OF THE\n       </b>\n</p>\n<p style=\"text-align:center\">\n<b>\n        HONG KONG SPECIAL ADMINISTRATIVE REGION\n       </b>\n</p>\n<p style=\"text-align:center\">\n<b>\n        COURT OF FIRST INSTANCE\n       </b>\n</p>\n<p style=\"text-align:center\">\n       CRIMINAL CASE NO 240 OF 2017\n      </p>\n<p style=\"text-align:center\">\n       ________________________\n      </p>\n<parties>\n<table border=\"0\" width=\"100%\">\n<tr>\n<td style=\"text-align:center\" width=\"25%\">\n</td>\n<td style=\"text-align:center\" width=\"50%\">\n          HKSAR\n         </td>\n<td style=\"text-align:center\" width=\"25%\">\n</td>\n</tr>\n<tr>\n<td style=\"text-align:center\" width=\"25%\">\n</td>\n<td style=\"text-align:center\" width=\"50%\">\n          v\n         </td>\n<td style=\"text-align:center\" width=\"25%\">\n</td>\n</tr>\n<tr>\n<td style=\"text-align:center\" width=\"25%\">\n</td>\n<td style=\"text-align:center\" width=\"50%\">\n          CHAN Man-sum, Ivan (陳文深)\n         </td>\n<td style=\"text-align:center\" width=\"25%\">\n</td>\n</tr>\n<tr>\n</tr>\n</table>\n</parties>\n<p style=\"text-align:center\">\n       ________________________\n      </p>\n<coram>\n<table border=\"0\" width=\"100%\">\n<tr>\n<td nowrap=\"\" valign=\"top\" width=\"15%\">\n          Before:\n         </td>\n<td valign=\"top\" width=\"85%\">\n          Hon Anthea Pang J\n         </td>\n</tr>\n</table>\n</coram>\n<date>\n<table border=\"0\" width=\"100%\">\n<tr>\n<td nowrap=\"\" valign=\"top\" width=\"15%\">\n          Date:\n         </td>\n<td valign=\"top\" width=\"85%\">\n          5 December 2017 at 6.51 pm\n         </td>\n</tr>\n</table>\n</date>\n<representation>\n<table border=\"0\" width=\"100%\">\n<tbody>\n<tr>\n<td nowrap=\"\" valign=\"top\" width=\"15%\">\n           Present:\n          </td>\n<td valign=\"top\" width=\"85%\">\n           Ms Anna Lai, SC, leading Mr Raymond Cheng, ADPP of the Department of Justice, for HKSAR\n          </td>\n</tr>\n<tr>\n<td nowrap=\"\" valign=\"top\" width=\"15%\">\n</td>\n<td valign=\"top\" width=\"85%\">\n           Mr Chui Fook-leung Steve, instructed by Khoo &amp; Co, assigned by DLA, for the accused\n          </td>\n</tr>\n</tbody>\n</table>\n</representation>\n<charge>\n<table border=\"0\" width=\"100%\">\n<tbody>\n<tr>\n<td nowrap=\"\" valign=\"top\" width=\"15%\">\n           Offence:\n          </td>\n<td valign=\"top\" width=\"85%\">\n           Murder (謀殺)\n          </td>\n</tr>\n</tbody>\n</table>\n</charge>\n<p style=\"text-align:center\">\n       ________________________\n      </p>\n<p style=\"text-align:center\">\n       Transcript of the Audio Recording\n       <br/>\n       of the Sentence in the above Case\n      </p>\n<p style=\"text-align:center\">\n       ________________________\n      </p>\n<br/>\n<p>\n       COURT: Accused, since you have been convicted of murder by the jury, there is only one possible sentence which is a mandatory one and I am bound by law to impose that sentence on you.\n      </p>\n<blockquote>\n<p>\n        You are ordered to serve a life imprisonment.\n       </p>\n</blockquote>\n<p>\n</p>\n<p>\n</p>\n</td>\n</tr>\n</table>\n</form>\n</body>\n</html>\n",
